generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id               Int                 @id @default(autoincrement())
  name             String
  slug             String              @unique
  address          String?
  phone            String?
  createdAt        DateTime            @default(now())
  directorName     String?
  educationalLevel String?             @default("Primaria Comunitaria Vocacional")
  years            AcademicYear[]
  courses          Course[]
  enrollments      Enrollment[]
  events           Event[]
  students         Student[]
  subjects         Subject[]
  assignments      SubjectAssignment[]
  users            User[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(TEACHER)
  createdAt DateTime @default(now())
  schoolId  Int
  teacher   Teacher?
  school    School   @relation(fields: [schoolId], references: [id])
}

model Teacher {
  id          Int                 @id @default(autoincrement())
  userId      Int                 @unique
  firstName   String
  lastName    String
  assignments SubjectAssignment[]
  user        User                @relation(fields: [userId], references: [id])
}

model Student {
  id          Int          @id @default(autoincrement())
  rude        String       @unique
  firstName   String
  lastName    String
  gender      String       @default("M") // M = Masculino, F = Femenino
  phone       String?
  birthDate   DateTime?
  isActive    Boolean      @default(true)
  schoolId    Int
  enrollments Enrollment[]
  school      School       @relation(fields: [schoolId], references: [id])
}

model Course {
  id          Int                 @id @default(autoincrement())
  level       String
  parallel    String
  schoolId    Int
  school      School              @relation(fields: [schoolId], references: [id])
  enrollments Enrollment[]
  evaluations Evaluation[]
  assignments SubjectAssignment[]

  @@unique([level, parallel, schoolId], name: "level_parallel_school")
}

model Subject {
  id              Int                 @id @default(autoincrement())
  name            String
  sortOrder       Int                 @default(0)
  schoolId        Int
  attendances     Attendance[]
  dimensionScores DimensionScore[]
  evaluations     Evaluation[]
  grades          Grade[]
  school          School              @relation(fields: [schoolId], references: [id])
  assignments     SubjectAssignment[]

  @@unique([name, schoolId])
}

model AcademicYear {
  id          Int                 @id @default(autoincrement())
  year        Int
  schoolId    Int
  school      School              @relation(fields: [schoolId], references: [id])
  enrollments Enrollment[]
  assignments SubjectAssignment[]

  @@unique([year, schoolId])
}

model Enrollment {
  id               Int               @id @default(autoincrement())
  studentId        Int
  courseId         Int
  academicYearId   Int
  createdAt        DateTime          @default(now())
  schoolId         Int
  attendances      Attendance[]
  dimensionScores  DimensionScore[]
  academicYear     AcademicYear      @relation(fields: [academicYearId], references: [id])
  course           Course            @relation(fields: [courseId], references: [id])
  school           School            @relation(fields: [schoolId], references: [id])
  student          Student           @relation(fields: [studentId], references: [id])
  evaluationScores EvaluationScore[]
  grades           Grade[]

  @@unique([studentId, academicYearId])
}

model SubjectAssignment {
  id             Int          @id @default(autoincrement())
  teacherId      Int
  subjectId      Int
  courseId       Int
  academicYearId Int
  schoolId       Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  course         Course       @relation(fields: [courseId], references: [id])
  school         School       @relation(fields: [schoolId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
  teacher        Teacher      @relation(fields: [teacherId], references: [id])

  @@unique([subjectId, courseId, academicYearId])
}

model Grade {
  id           Int        @id @default(autoincrement())
  score        Int
  period       Int
  enrollmentId Int
  subjectId    Int
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  subject      Subject    @relation(fields: [subjectId], references: [id])

  @@unique([enrollmentId, subjectId, period])
}

model Attendance {
  id           Int        @id @default(autoincrement())
  date         DateTime   @default(now())
  status       String
  enrollmentId Int
  subjectId    Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  subject      Subject    @relation(fields: [subjectId], references: [id])

  @@unique([date, enrollmentId, subjectId])
}

model Evaluation {
  id        Int               @id @default(autoincrement())
  title     String
  dimension String
  courseId  Int
  subjectId Int
  period    Int
  course    Course            @relation(fields: [courseId], references: [id])
  subject   Subject           @relation(fields: [subjectId], references: [id])
  scores    EvaluationScore[]
  @@unique([title, subjectId, period, courseId])
}

model EvaluationScore {
  id           Int        @id @default(autoincrement())
  score        Int
  evaluationId Int
  enrollmentId Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id])

  @@unique([evaluationId, enrollmentId])
}

model DimensionScore {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  subjectId    Int
  period       Int
  ser          Int        @default(0)
  autoSer      Int        @default(0)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  subject      Subject    @relation(fields: [subjectId], references: [id])

  @@unique([enrollmentId, subjectId, period])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  description String?
  updatedAt   DateTime @updatedAt
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
}

enum Role {
  ADMIN
  TEACHER
  SUPER_ADMIN
}
